generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ScannedEmail {
  id         String   @id @default(cuid())
  messageId  String   @unique
  subject    String
  fromAddr   String
  snippet    String
  emailDate  DateTime
  category   String
  isSpam     Boolean  @default(false)
  scanBatch   String
  sourceEmail String   @default("")
  scannedAt   DateTime @default(now())
}

model RecurringItem {
  id              String   @id @default(cuid())
  name            String
  icon            String
  frequencyMonths Int      @default(0)
  lastDate        DateTime?
  provider        String   @default("")
  notes           String?
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model UrgentItem {
  id          String    @id @default(cuid())
  icon        String
  text        String
  detail      String    @default("")
  color       String    @default("red")
  dismissed   Boolean   @default(false)
  dismissedAt DateTime?
  createdAt   DateTime  @default(now())
}

model SchoolEvent {
  id          String @id @default(cuid())
  dateDisplay String
  eventText   String
  source      String @default("")
  type        String @default("event")
  sortKey     String @default("")
}

model GmailAccount {
  id           String   @id @default(cuid())
  email        String   @unique
  accessToken  String?
  refreshToken String?
  addedAt      DateTime @default(now())
  lastScanAt   DateTime?
  isActive     Boolean  @default(true)
}

model Upload {
  id          String   @id @default(cuid())
  filename    String
  url         String
  caption     String   @default("")
  category    String   @default("general")
  notes       String   @default("")
  createdAt   DateTime @default(now())
}
